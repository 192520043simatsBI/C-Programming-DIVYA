#include <stdio.h>

int main() {
    int n, temp, rem, sum = 0;

    printf("Enter number: ");
    scanf("%d", &n);

    temp = n;

    // Find sum of digits
    while(temp > 0) {
        rem = temp % 10;
        sum += rem;
        temp /= 10;
    }

    // Check Harshad
    if(n % sum == 0)
        printf("Harshad Number");
    else
        printf("Not Harshad Number");

    return 0;
}
